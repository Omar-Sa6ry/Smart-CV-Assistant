generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship
  freelance
}

enum Degree {
  diploma
  bachelor
  master
  ungraduated
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique @db.VarChar(100)
  password         String?
  role             String    @default("USER")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  firstName        String?   @db.VarChar(100)
  googleId         String?   @unique
  headline         String?   @db.VarChar(200)
  lastLoginAt      DateTime?
  lastName         String?   @db.VarChar(100)
  resetToken       String?
  resetTokenExpiry DateTime? @db.Timestamp(6)
  cvs              Cv[]
  experiences      Experience[]
  educations       Education[]
  certifications  Certification[]
  projects        Project[]
  languages       Language[]
  skills          Skill[]
}

model Cv {
  id          String   @id @default(uuid())
  userId      String
  title       String
  summary         String
  isDefault Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  experiences Experience[]
  educations  Education[]
  certifications Certification[]
  projects       Project[]
  languages      Language[]
  skills         Skill[]

  @@map("CV")
}

model Experience {
  id             String         @id @default(uuid())
  userId         String
  cvId           String
  jobTitle       String         @db.VarChar(75)
  companyName    String         @db.VarChar(150)
  companyWebsite String?        @db.VarChar(250)
  location       String?        @db.VarChar(255)
  startDate      DateTime
  endDate        DateTime?
  isCurrentJob   Boolean        @default(false)
  description    String        @db.VarChar(255)
  achievements   String?        @db.Text
  employmentType EmploymentType @default(full_time)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Education {
  id             String         @id @default(uuid())
  userId         String
  cvId           String
  institution       String         @db.VarChar(75)
  title    String         @db.VarChar(150)
  location       String?        @db.VarChar(255)
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean        @default(false)
  gpa            Decimal?       @db.Decimal(3, 2)
  description    String         @db.VarChar(500)
  degree         Degree 
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Certification {
  id                  String   @id @default(uuid())
  userId              String
  cvId                String
  name                String   @db.VarChar(255)
  issuingOrganization String   @db.VarChar(255)
  credentialId        String?  @db.VarChar(100)
  credentialUrl       String?  @db.VarChar(250)
  issueDate           DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Project {
  id               String    @id @default(uuid())
  userId           String
  cvId             String
  name             String    @db.VarChar(150)
  description      String?   @db.VarChar(250)
  technologiesUsed String?   @db.Text
  projectUrl       String?   @db.VarChar(500)
  isPersonalProject Boolean   @default(true)
  startDate        DateTime?
  endDate          DateTime?
  isTeamProject    Boolean   @default(false)
  teamSize         Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

enum Proficiency {
  basic
  conversational
  professional
  fluent
  native
}

model Language {
  id          String      @id @default(uuid())
  userId      String
  cvId        String
  name        String      @db.VarChar(100)
  proficiency Proficiency @default(professional)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

enum SkillCategory {
  technical
  soft
  tool
  methodology
  programming_language
}

enum SkillProficiency {
  beginner
  intermediate
  advanced
  expert
}

model SkillKeyword {
  id              String        @id @default(uuid())
  name            String        @unique @db.VarChar(100)
  category        SkillCategory @default(technical)
  popularityScore Int           @default(0)
  isVerified      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  skills          Skill[]
}

model Skill {
  id             String           @id @default(uuid())
  userId         String
  cvId           String
  keywordId      String?
  name           String           @db.VarChar(100)
  proficiency    SkillProficiency @default(intermediate)
  yearsOfExperience Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv      Cv            @relation(fields: [cvId], references: [id], onDelete: Cascade)
  keyword SkillKeyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)
}
