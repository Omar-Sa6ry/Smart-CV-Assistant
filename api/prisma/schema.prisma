generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship
  freelance
}

enum Degree {
  diploma
  bachelor
  master
  ungraduated
}

enum Proficiency {
  basic
  conversational
  professional
  fluent
  native
}

enum SkillCategory {
  programming_language
  frontend
  backend
  mobile
  game_development
  embedded_systems
  technical
  database_storage
  data_science_analytics
  ai_machine_learning
  cloud_computing
  devops_infrastructure
  networking
  testing_qa
  architecture_design
  security
  software_tools
  methodology
  soft_skills
  domain_knowledge
}

enum SkillProficiency {
  beginner
  intermediate
  advanced
  expert
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique @db.VarChar(100)
  password         String?
  role             String    @default("USER")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  firstName        String?   @db.VarChar(100)
  googleId         String?   @unique
  lastLoginAt      DateTime?
  lastName         String?   @db.VarChar(100)
  resetToken       String?
  resetTokenExpiry DateTime? @db.Timestamp(6)
  cvs              Cv[]
  experiences      Experience[]
  educations       Education[]
  certifications  Certification[]
  projects        Project[]
  languages       Language[]
  skills          Skill[]
}

model Cv {
  id          String   @id @default(uuid())
  userId      String
  title       String   @db.VarChar(100)
  headline    String   @db.VarChar(100)
  summary     String   @db.VarChar(2000)
  portfolio   String?  @db.VarChar(500)
  linkedin    String?  @db.VarChar(500)
  github      String?  @db.VarChar(500)
  phone       String   @db.VarChar(20)
  location    String   @db.VarChar(255)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  experiences Experience[]
  educations  Education[]
  certifications Certification[]
  projects       Project[]
  languages      Language[]
  skills         Skill[]

  @@map("CV")
}

model Experience {
  id             String         @id @default(uuid())
  userId         String
  cvId           String
  jobTitle       String         @db.VarChar(75)
  companyName    String         @db.VarChar(150)
  companyWebsite String        @db.VarChar(250)
  location       String        @db.VarChar(255)
  startDate      DateTime
  endDate        DateTime?
  isCurrentJob   Boolean        @default(false)
  description    String        @db.VarChar(2000)
  employmentType EmploymentType @default(full_time)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Education {
  id             String         @id @default(uuid())
  userId         String
  cvId           String
  institution       String         @db.VarChar(75)
  title    String         @db.VarChar(150)
  location       String?        @db.VarChar(255)
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean        @default(false)
  gpa            Decimal?       @db.Decimal(3, 2)
  description    String         @db.VarChar(1000)
  degree         Degree 
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Certification {
  id                  String   @id @default(uuid())
  userId              String
  cvId                String
  name                String   @db.VarChar(255)
  issuingOrganization String   @db.VarChar(255)
  credentialId        String?  @db.VarChar(100)
  credentialUrl       String  @db.VarChar(250)
  issueDate           DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Project {
  id               String    @id @default(uuid())
  userId           String
  cvId             String
  name             String    @db.VarChar(150)
  description      String   @db.VarChar(2000)
  projectUrl       String   @db.VarChar(500)
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}



model Language {
  id          String      @id @default(uuid())
  userId      String
  cvId        String
  name        String      @db.VarChar(100)
  proficiency Proficiency @default(professional)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cv   Cv   @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model SkillKeyword {
  id              String        @id @default(uuid())
  name            String        @unique @db.VarChar(100)
  category        SkillCategory @default(technical)
  popularityScore Int           @default(0)
  isVerified      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  skills          Skill[]
}

model Skill {
  id             String           @id @default(uuid())
  userId         String
  cvId           String
  keywordId      String?
  name           String           @db.VarChar(100)
  category       SkillCategory    @default(technical)
  proficiency    SkillProficiency @default(intermediate)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv      Cv            @relation(fields: [cvId], references: [id], onDelete: Cascade)
  keyword SkillKeyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)
}
